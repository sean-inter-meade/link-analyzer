run = "pip install -r requirements.txt && python -m spacy download en_core_web_sm && uvicorn backend.app:app --host 0.0.0.0 --port 8080"

entrypoint = "backend/app.py"
modules = ["python-3.11"]

[nix]
channel = "stable-24_05"
packages = ["libxcrypt", "libyaml"]

[env]
PYTHONPATH = "/home/runner/${REPL_SLUG}"

[deployment]
run = ["sh", "-c", "uvicorn backend.app:app --host 0.0.0.0 --port 8080"]
deploymentTarget = "cloudrun"

[[ports]]
localPort = 8080
externalPort = 80

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "uvicorn backend.app:app --host 0.0.0.0 --port 8080"
waitForPort = 8080

[agent]
expertMode = true
