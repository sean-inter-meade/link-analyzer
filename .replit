run = "pip install -r requirements.txt && python -m spacy download en_core_web_sm && uvicorn backend.app:app --host 0.0.0.0 --port 8080"

entrypoint = "backend/app.py"

[nix]
channel = "stable-24_05"

[env]
PYTHONPATH = "/home/runner/${REPL_SLUG}"

[deployment]
run = ["sh", "-c", "uvicorn backend.app:app --host 0.0.0.0 --port 8080"]
deploymentTarget = "cloudrun"

[[ports]]
localPort = 8080
externalPort = 80
