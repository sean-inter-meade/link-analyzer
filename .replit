run = "if [ ! -d .venv ]; then python -m venv .venv; fi && . .venv/bin/activate && pip install -r requirements.txt && python -m spacy download en_core_web_sm && uvicorn backend.app:app --host 0.0.0.0 --port 8080"

entrypoint = "backend/app.py"
modules = ["python-3.11"]

[nix]
channel = "stable-24_05"
packages = ["libxcrypt", "libyaml", "gcc"]

[env]
PYTHONPATH = "/home/runner/${REPL_SLUG}"
PIP_USER = "0"
USE_TRANSFORMER = "true"
HF_HOME = "/home/runner/${REPL_SLUG}/.hf_cache"
TRANSFORMERS_OFFLINE = "1"
HF_HUB_OFFLINE = "1"

[deployment]
run = ["sh", "-c", ". .venv/bin/activate && uvicorn backend.app:app --host 0.0.0.0 --port 8080"]
deploymentTarget = "cloudrun"
build = ["sh", "-c", "rm -rf .venv && python -m venv .venv && . .venv/bin/activate && pip install -r requirements.txt && python -m spacy download en_core_web_sm && TRANSFORMERS_OFFLINE=0 HF_HUB_OFFLINE=0 python -c \"from transformers import pipeline; pipeline('zero-shot-classification', model='valhalla/distilbart-mnli-12-1')\""]

[[ports]]
localPort = 8080
externalPort = 80

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = ". .venv/bin/activate && uvicorn backend.app:app --host 0.0.0.0 --port 8080"
waitForPort = 8080

[agent]
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 180000
